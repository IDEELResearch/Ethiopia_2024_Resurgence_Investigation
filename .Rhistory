labs(
x = "Year",
y = expression("Mean " * pi),
size = "Sample size"
) +
scale_y_continuous(
labels = scales::label_number(),
expand = expansion(mult = c(0.1, 0.2))
) +
theme_bw() +
theme(
axis.text = element_text(size = 10),
axis.title = element_text(size = 12),
strip.text = element_text(size = 12),
axis.text.x = element_text(angle = 45, hjust = 1)
)
pi_summary %>%
ggplot(aes(x = pop, y = mean_pi)) +
geom_errorbar(aes(x = pop, ymin = mean_pi - pi_se, ymax = mean_pi + pi_se),
width = 0.15,
linewidth = 0.7,
linetype = "dashed"
) +
geom_line(group = 1, color = "gray", linewidth = 1) +
geom_point(aes(size = sample_count)) +
geom_label(
aes(label = sample_count),
size = 3,
vjust = -0.5,
hjust = -0.2,
fill = "white",
color = "black"
) +
labs(
x = "Year",
y = expression("Mean " * pi),
size = "Sample size"
) +
scale_y_continuous(
labels = scales::label_number(),
expand = expansion(mult = c(0.1, 0.2))
) +
theme_bw() +
theme(
axis.text = element_text(size = 10),
axis.title = element_text(size = 12),
strip.text = element_text(size = 12),
axis.text.x = element_text(angle = 45, hjust = 1)
)
